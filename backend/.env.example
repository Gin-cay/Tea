# 复制为 .env 后修改。生产环境建议使用 systemd EnvironmentFile 指向此文件。

# 本地开发（默认）
# database_url=sqlite:///./tea_data.db

# 生产：同机 MySQL / MariaDB（须已建库与用户，见 deploy/mysql_init.sql）
database_url=mysql+pymysql://tea:你的密码@127.0.0.1:3306/tea?charset=utf8mb4

jwt_secret=请替换为至少32字节的随机字符串
wechat_appid=
wechat_secret=

# 与小程序 app.js globalData.traceTokenSecret 保持一致
trace_token_secret=TEA_RED_TRACE_DEV_SECRET_REPLACE

# 小程序上传图片、溯源等对外访问的 API 根 URL（须含 https:// 域名，无尾斜杠）
public_base_url=https://api.你的域名.com

# 管理端 CRUD：请求头 X-Admin-Token；留空则 /api/admin/* 全部 403
admin_token=

# 微信支付（认养下单）；不配则仅返回提示，无法真实扣款
wechat_mchid=
wechat_pay_serial_no=
wechat_pay_private_key_path=
wechat_pay_apiv3_key=
mini_program_appid=
dev_payment_stub=false

# 研学答题：满分 3，得分 ≥ 该值则颁发电子证书（例如 3 表示必须全对）
# study_quiz_pass_min_score=2
