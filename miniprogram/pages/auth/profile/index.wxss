.sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.mt {
  margin-top: 18rpx;
}

.mt2 {
  margin-top: 22rpx;
}

.role-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.role-chip {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 16rpx;
  background: rgba(237, 247, 236, 0.55);
  border: 1rpx solid rgba(47, 143, 58, 0.14);
  color: #2f8f3a;
  font-size: 24rpx;
  font-weight: 700;
}

.role-chip--active {
  background: #2f8f3a;
  color: #fff;
}

.avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(237, 247, 236, 0.35);
  border: 1rpx solid rgba(47, 143, 58, 0.1);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.avatar-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.input {
  margin-top: 10rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  font-size: 24rpx;
  color: #111827;
}

.picker {
  margin-top: 10rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder {
  color: #9ca3af;
}

.arrow {
  color: #9ca3af;
  font-size: 34rpx;
  line-height: 1;
}

.ghost-btn,
.primary-btn {
  margin: 0;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.ghost-btn {
  color: #2f8f3a;
  background: #fff;
  border: 1rpx solid rgba(47, 143, 58, 0.18);
}

.primary-btn {
  color: #fff;
  background: #2f8f3a;
  border: none;
  height: 72rpx;
  line-height: 72rpx;
  font-weight: 700;
}

.ghost-btn::after,
.primary-btn::after {
  border: none;
}

