.head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.badge {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #2f8f3a;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(47, 143, 58, 0.18);
}

.sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 6rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.06);
}

.row-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  padding-top: 14rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.hint {
  font-size: 22rpx;
}

.input {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  color: #111827;
}

.textarea {
  width: 100%;
  min-height: 98rpx;
  padding: 12rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: rgba(237, 247, 236, 0.35);
  border: 1rpx solid rgba(47, 143, 58, 0.12);
  font-size: 24rpx;
  color: #111827;
  margin-top: 10rpx;
}

.pick-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.ghost-btn,
.primary-btn {
  flex: 1;
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.ghost-btn {
  color: #2f8f3a;
  background: #fff;
  border: 1rpx solid rgba(47, 143, 58, 0.18);
}

.primary-btn {
  color: #fff;
  background: #2f8f3a;
  border: none;
}

.ghost-btn::after,
.primary-btn::after {
  border: none;
}

.picked {
  margin-top: 14rpx;
}

.picked-title {
  font-size: 22rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.picked-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.picked-img {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #e5e7eb;
}

.submit-row {
  margin-top: 14rpx;
}

.remind-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.picker-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(237, 247, 236, 0.6);
  border: 1rpx solid rgba(47, 143, 58, 0.16);
  color: #2f8f3a;
  font-size: 22rpx;
  font-weight: 700;
}

