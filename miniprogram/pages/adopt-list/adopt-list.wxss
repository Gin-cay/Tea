.list-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 24rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.top-banner {
  margin: 24rpx 0 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2f8f3a 0%, #4caf50 45%, #81c784 100%);
  box-shadow: 0 8rpx 24rpx rgba(47, 143, 58, 0.25);
}

.banner-text {
  display: block;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: center;
}

.cat-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.cat-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.cat-chip {
  flex-shrink: 0;
  max-width: 420rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #374151;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(47, 143, 58, 0.2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-chip--on {
  color: #fff;
  background: #2f8f3a;
  border-color: #2f8f3a;
}

.sort-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 8rpx 20rpx;
}

.sort-item {
  font-size: 26rpx;
  color: #6b7280;
  padding: 8rpx 12rpx;
}

.sort-item--on {
  color: #2f8f3a;
  font-weight: 600;
}

.list-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(31, 41, 55, 0.08);
}

.goods-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.goods-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.goods-name-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
  flex: 1;
  min-width: 0;
}

.goods-red-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(90deg, #c9302c, #e85d5d);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.goods-cycle {
  font-size: 24rpx;
  color: #2f8f3a;
  margin-bottom: 12rpx;
}

.progress-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e8f5e9;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #43a047, #2f8f3a);
}

.progress-txt {
  font-size: 22rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.goods-meta {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.goods-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
}

.goods-price-block {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #e1583f;
}

.goods-join {
  font-size: 22rpx;
  color: #9ca3af;
}

.btn-join {
  margin: 0;
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  color: #fff;
  background: #2f8f3a;
  border-radius: 999rpx;
  border: none;
}

.btn-join::after {
  border: none;
}
