<page-background>
<view class="page">
  <view class="card" wx:if="{{loadError}}">
    <view class="muted">{{loadError}}</view>
  </view>

  <view class="card" wx:if="{{!list.length && !loadError}}">
    <view class="muted">暂无收藏商品。在商城商品详情页点击「收藏」即可加入。</view>
    <button class="btn" bindtap="goMall">去逛逛</button>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card row" data-id="{{item.id}}" bindtap="goDetail">
      <image class="cover" src="{{item.coverUrl || '/images/banner-mall.png'}}" mode="aspectFill" />
      <view class="meta">
        <view class="title">{{item.name}}</view>
        <view class="price">¥{{item.priceYuan}}</view>
      </view>
      <view class="del" catchtap="onRemove" data-id="{{item.id}}">移除</view>
    </view>
  </block>
</view>
</page-background>
