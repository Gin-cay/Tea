<page-background>
<view class="page">
  <view class="card" wx:if="{{story}}">
    <view class="section-title">{{story.title}}</view>
    <view class="story-meta muted">{{story.subtitle}}</view>
    <rich-text class="story-body" nodes="{{storyHtml}}" wx:if="{{storyHtml}}" />
    <view class="story-body muted" wx:else>暂无正文</view>
  </view>
  <view class="card" wx:else>
    <view class="muted">{{loadError || "未找到对应故事，请从首页或列表进入。"}}</view>
  </view>
</view>
</page-background>
