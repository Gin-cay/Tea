<page-background>
<view class="page">
  <view class="card" wx:if="{{story}}">
    <view class="section-title">{{story.title}}</view>
    <view class="story-meta muted">{{story.subtitle}}</view>
    <view class="story-body">{{story.body}}</view>
  </view>
  <view class="card" wx:else>
    <view class="muted">未找到对应故事，请从首页或列表进入。</view>
  </view>
</view>
</page-background>
