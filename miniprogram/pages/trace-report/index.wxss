.page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input {
  flex: 1;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.btn-scan {
  flex-shrink: 0;
}

.picker-val {
  padding: 16rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #2f8f3a;
}

.area {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.thumb.add {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  border: 2rpx dashed #ccc;
}

.submit {
  margin-top: 16rpx;
}

.muted {
  font-size: 24rpx;
  color: #888;
}
