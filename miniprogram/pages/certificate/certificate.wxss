.page {
  padding: 24rpx 24rpx 48rpx;
}

.cert-preview {
  margin-bottom: 32rpx;
}

.cert-border {
  background: #fffef8;
  border: 6rpx double #2f8f3a;
  border-radius: 8rpx;
  padding: 36rpx 28rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(47, 143, 58, 0.12);
}

.cert-ribbon {
  text-align: center;
  font-size: 26rpx;
  color: #c9302c;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.cert-h1 {
  text-align: center;
  font-size: 40rpx;
  font-weight: 800;
  margin: 20rpx 0 16rpx;
  color: #1a1a1a;
  letter-spacing: 8rpx;
}

.cert-line {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #2f8f3a, transparent);
  margin: 0 40rpx 24rpx;
}

.cert-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  font-size: 26rpx;
}

.cert-row .k {
  color: #6b7280;
  flex-shrink: 0;
}

.cert-row .v {
  text-align: right;
  color: #111;
  word-break: break-all;
}

.mono {
  font-family: monospace;
}

.cert-footer {
  text-align: center;
  font-size: 22rpx;
  margin-top: 28rpx;
}

.muted {
  color: #6b7280;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-save {
  margin: 0;
  background: #2f8f3a;
  color: #fff;
  border-radius: 16rpx;
  border: none;
  font-size: 30rpx;
}

.btn-save::after {
  border: none;
}

.btn-share {
  margin: 0;
  background: #fff;
  color: #2f8f3a;
  border: 2rpx solid #2f8f3a;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.btn-share::after {
  border: none;
}

.cert-canvas-hidden {
  position: fixed;
  left: -2000px;
  top: 0;
  width: 300px;
  height: 460px;
}
