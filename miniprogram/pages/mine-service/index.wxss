.page {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 12rpx;
}

.k {
  width: 200rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.v {
  flex: 1;
  font-size: 28rpx;
  color: #111;
  word-break: break-all;
}

.btn-line {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2f8f3a;
  background: #edf7ec;
  border-radius: 12rpx;
}

.mt {
  margin-top: 28rpx;
}

.notice {
  margin-top: 28rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.hint {
  font-size: 24rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: #2f8f3a;
  color: #fff;
  border-radius: 12rpx;
}

.muted {
  color: #666;
}
