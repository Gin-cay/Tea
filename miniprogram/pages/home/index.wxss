.banner {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-item {
  height: 100%;
  position: relative;
}

.banner-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  z-index: 1;
  left: 24rpx;
  bottom: 24rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.category-item {
  background: #edf7ec;
  color: #2f8f3a;
  border-radius: 14rpx;
  text-align: center;
  padding: 16rpx 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: 0;
}

.item-title {
  font-size: 30rpx;
  margin-bottom: 6rpx;
}

.price {
  color: #e1583f;
  font-size: 30rpx;
  font-weight: 600;
}

.tag {
  color: #2f8f3a;
  background: #edf7ec;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}

/* ========== 茶韵红史：与 .card / .section-title 复用全局 app.wxss ========== */

/* 双列自适应：窄屏自动折行，保证可点区域足够大 */
.tea-history-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: stretch;
}

.tea-history-card {
  flex: 1 1 300rpx;
  min-width: 0;
  background: #edf7ec;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(47, 143, 58, 0.12);
}

/* 红色主题卡片：浅绿底上略偏暖，与「红色茶源」语义呼应 */
.tea-history-card--red {
  background: linear-gradient(160deg, #f5faf4 0%, #f0f5ee 100%);
  border-color: rgba(201, 48, 44, 0.15);
}

.tea-history-card-head {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.tea-history-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.tea-history-card-head-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tea-history-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.tea-history-card-sub {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
}

.tea-history-mini-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tea-history-mini-item {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
}

.tea-history-mini-item:active {
  opacity: 0.92;
}

.tea-history-mini-title {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.4;
  display: block;
}

/* 红色溯源入口：高识别度红色标识 + 浅绿底协调 */
.red-trace-entry {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(100deg, #fff5f5 0%, #f0f7ec 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(201, 48, 44, 0.22);
}

.red-trace-entry:active {
  opacity: 0.96;
}

.red-trace-entry-badge {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #c9302c, #e85d5d);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.red-trace-entry-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.red-trace-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.red-trace-entry-desc {
  font-size: 22rpx;
  line-height: 1.4;
}

.red-trace-entry-arrow {
  font-size: 40rpx;
  color: #c9302c;
  flex-shrink: 0;
}
