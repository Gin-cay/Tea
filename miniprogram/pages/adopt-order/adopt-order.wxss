.order-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.order-card {
  margin-bottom: 20rpx;
}

.order-label {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.order-goods {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.order-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.order-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.order-cycle {
  font-size: 24rpx;
  color: #2f8f3a;
  margin-bottom: 8rpx;
}

.order-period {
  font-size: 24rpx;
  color: #6b7280;
}

.order-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #374151;
}

.order-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #e1583f;
}

.order-tip {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.55;
}

.order-spacer {
  height: 40rpx;
}

.order-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -4rpx 24rpx rgba(31, 41, 55, 0.08);
}

.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.order-total {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.order-total-label {
  font-size: 26rpx;
  color: #6b7280;
}

.order-total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #e1583f;
}

.btn-pay {
  margin: 0;
  flex-shrink: 0;
  min-width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: #2f8f3a;
  border-radius: 40rpx;
  border: none;
}

.btn-pay::after {
  border: none;
}

.order-empty {
  padding: 24rpx;
}
