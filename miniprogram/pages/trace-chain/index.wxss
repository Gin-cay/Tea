/* 全流程溯源：简洁、正式、适配移动端 */

.page {
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.state-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid #e8e8e8;
}

.muted {
  color: #6b7280;
  font-size: 28rpx;
}

.err-text {
  color: #b91c1c;
  font-size: 28rpx;
  display: block;
  margin-bottom: 24rpx;
}

.btn-retry {
  margin: 0 auto;
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #1a5f2a;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

/* 顶部产品区 */
.hero-card {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  background: #f0f4ef;
  border: 1rpx solid #d4e4d4;
}

.hero-img {
  width: 100%;
  height: 360rpx;
  display: block;
}

.hero-fallback {
  height: 280rpx;
  line-height: 280rpx;
  text-align: center;
  font-size: 40rpx;
  color: #1a5f2a;
  font-weight: 700;
  background: linear-gradient(180deg, #e8f5e9, #fff);
}

.hero-mask {
  padding: 24rpx 28rpx 28rpx;
  background: #fff;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.35;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.45;
}

.trace-no-row {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f8faf8;
  border-radius: 12rpx;
  border: 1rpx dashed #2f8f3a;
}

.trace-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
}

.trace-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #14532d;
  letter-spacing: 1rpx;
  word-break: break-all;
}

.hero-meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.hero-meta .dot {
  margin: 0 8rpx;
}

/* 区块标题 */
.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 时间线 */
.timeline-wrap {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx 24rpx 8rpx;
  border: 1rpx solid #e5e7eb;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
}

.timeline-axis {
  width: 48rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.axis-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d1d5db;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #d1d5db;
  margin-top: 28rpx;
}

.axis-dot.on {
  background: #2f8f3a;
  box-shadow: 0 0 0 2rpx #2f8f3a;
}

.axis-line {
  width: 2rpx;
  flex: 1;
  min-height: 24rpx;
  background: linear-gradient(180deg, #d1d5db, #e5e7eb);
  margin: 8rpx 0 0;
}

.timeline-body {
  flex: 1;
  min-width: 0;
  padding-bottom: 16rpx;
}

.node-card {
  padding: 20rpx 16rpx 16rpx 0;
}

.node-head {
  position: relative;
  padding-right: 40rpx;
}

.node-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.node-step {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #1a5f2a;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.node-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.node-time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.node-arrow {
  position: absolute;
  right: 0;
  top: 4rpx;
  font-size: 28rpx;
  color: #9ca3af;
}

.node-summary {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
}

.node-detail {
  padding: 0 0 8rpx 0;
  border-top: 1rpx solid #f3f4f6;
  margin-top: 8rpx;
  padding-top: 16rpx;
}

.field-row {
  display: flex;
  flex-wrap: wrap;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f9fafb;
  font-size: 26rpx;
}

.field-label {
  width: 200rpx;
  flex-shrink: 0;
  color: #6b7280;
}

.field-value {
  flex: 1;
  min-width: 0;
  color: #111827;
  line-height: 1.45;
}

.sub-wrap {
  margin-top: 20rpx;
}

.sub-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a5f2a;
  margin-bottom: 12rpx;
}

.sub-step {
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid #2f8f3a;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.sub-meta {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 6rpx;
}

.sub-remark {
  font-size: 24rpx;
  color: #4b5563;
  margin-top: 8rpx;
  line-height: 1.45;
}

.media-wrap {
  margin-top: 20rpx;
}

.media-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 12rpx;
}

.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.trace-video {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: #000;
}

.video-cap {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

/* 底部资质 */
.footer-card {
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
}

.footer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #2f8f3a;
}

.footer-block {
  margin-bottom: 20rpx;
}

.footer-block:last-child {
  margin-bottom: 0;
}

.footer-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a5f2a;
  margin-bottom: 8rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.55;
}

.page-pad-bottom {
  height: 24rpx;
}
