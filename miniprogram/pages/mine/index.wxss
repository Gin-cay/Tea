.profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #d1d5db;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #e5e7eb;
  flex-shrink: 0;
}

.name {
  font-size: 34rpx;
  margin-bottom: 8rpx;
}

.order-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.order-item {
  text-align: center;
  background: #edf7ec;
  color: #2f8f3a;
  border-radius: 12rpx;
  padding: 16rpx 0;
}

.order-item:active {
  opacity: 0.85;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-red-tag {
  font-size: 20rpx;
  color: #fff;
  background: #c9302c;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}
