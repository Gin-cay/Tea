.study-hero {
  background: linear-gradient(135deg, #fff5f5, #edf7ec);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 48, 44, 0.15);
}

.study-hero-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #c9302c;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.study-hero-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.spot-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.spot-item:last-child {
  border-bottom: 0;
}

.spot-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.spot-badge {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #fff;
  background: #c9302c;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.spot-foot {
  margin-top: 10rpx;
}

.route-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.route-item:last-child {
  border-bottom: 0;
}

.route-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.route-days {
  font-size: 24rpx;
  color: #2f8f3a;
  font-weight: 600;
}

.booking-tip {
  margin-top: 10rpx;
  line-height: 1.45;
}

.route-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.btn-mini {
  margin: 0;
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #edf7ec;
  color: #2f8f3a;
  border-radius: 999rpx;
  border: none;
}

.btn-mini::after {
  border: none;
}

.btn-mini--red {
  background: rgba(201, 48, 44, 0.12);
  color: #c9302c;
}

.row-points {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.points {
  color: #c9302c;
  font-weight: 700;
  font-size: 34rpx;
}

.btn-checkin {
  margin: 20rpx 0 0;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #c9302c, #e1583f);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
}

.btn-checkin::after {
  border: none;
}
