.trace-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(90deg, rgba(201, 48, 44, 0.12), #edf7ec);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 48, 44, 0.2);
}

.trace-banner-icon {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #c9302c;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

.trace-banner-txt {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.para {
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 8rpx;
}

.coord {
  margin-top: 12rpx;
}

.tip {
  margin-top: 8rpx;
}

.farmer-row {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.farmer-av {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.farmer-meta {
  flex: 1;
  min-width: 0;
}

.red-cover {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.sub {
  margin-bottom: 8rpx;
}

.proc-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.proc-item:last-child {
  border-bottom: 0;
}

.proc-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.proc-title {
  font-size: 28rpx;
  font-weight: 600;
}

.proc-pct {
  font-size: 26rpx;
  color: #c9302c;
  font-weight: 600;
}

.progress-track {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #2f8f3a;
  border-radius: 999rpx;
}

.progress-fill--red {
  background: linear-gradient(90deg, #c9302c, #e85d5d);
}

.btn-link {
  margin: 20rpx 0 0;
  font-size: 26rpx;
  color: #c9302c;
  background: rgba(201, 48, 44, 0.08);
  border-radius: 999rpx;
  border: none;
}

.btn-link::after {
  border: none;
}

.btn-back {
  margin-top: 24rpx;
  background: #2f8f3a;
  color: #fff;
  border-radius: 999rpx;
  border: none;
}

.btn-back::after {
  border: none;
}

/* ========== 茶树数字孪生（四季横向轴）========== */

.twin-wrap {
  overflow: hidden;
}

.twin-sub {
  margin-bottom: 16rpx;
  line-height: 1.45;
}

/* 顶部季节标签横滑（窄屏也能划） */
.twin-chip-scroll {
  width: 100%;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.twin-chip-row {
  display: inline-block;
  padding: 4rpx 2rpx 8rpx;
  white-space: nowrap;
}

.twin-chip {
  display: inline-block;
  vertical-align: middle;
  margin-right: 16rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #4b5563;
  background: #f3f4f6;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
}

.twin-chip:last-child {
  margin-right: 0;
}

.twin-chip--active {
  color: #fff;
  background: linear-gradient(90deg, #2f8f3a, #52b364);
  border-color: rgba(47, 143, 58, 0.35);
  font-weight: 600;
}

/* 经典横向 scroll-view：子项 inline-block + white-space:nowrap */
.twin-pan-scroll {
  width: 100%;
  white-space: nowrap;
}

.twin-pan-card {
  display: inline-block;
  vertical-align: top;
  width: 600rpx;
  max-width: 86vw;
  margin-right: 20rpx;
  background: #f9fcf8;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 58, 0.15);
  box-sizing: border-box;
}

.twin-pan-card:last-child {
  margin-right: 0;
}

.twin-pan-img {
  width: 100%;
  height: 280rpx;
  display: block;
  background: #e5e7eb;
}

.twin-pan-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2f8f3a;
  padding: 16rpx 20rpx 8rpx;
}

.twin-pan-diary {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.65;
  padding: 0 20rpx 20rpx;
}
