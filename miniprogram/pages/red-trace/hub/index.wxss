/* 红色溯源枢纽页：延续全局浅绿 + 白卡片，点缀红色主题 */

.red-hero {
  background: linear-gradient(135deg, #fff5f5 0%, #edf7ec 55%, #ffffff 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 48, 44, 0.12);
  box-sizing: border-box;
}

.red-hero-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(90deg, #c9302c, #e85d5d);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
}

.red-hero-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.red-hero-sub {
  font-size: 24rpx;
  line-height: 1.5;
}

.hint {
  font-size: 24rpx;
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.btn-inline {
  margin: 0;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #fff;
  background: #2f8f3a;
  border-radius: 999rpx;
  border: none;
}

.btn-inline::after {
  border: none;
}

.btn-scan {
  margin: 0;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #c9302c;
  background: rgba(201, 48, 44, 0.08);
  border-radius: 16rpx;
  border: 1rpx dashed rgba(201, 48, 44, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn-scan::after {
  border: none;
}

.scan-icon {
  font-size: 32rpx;
}

.quick-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  flex: 1 1 200rpx;
  min-width: 0;
  background: #edf7ec;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(47, 143, 58, 0.12);
}

.quick-item--red {
  background: linear-gradient(160deg, #fff8f8 0%, #f0f7ee 100%);
  border-color: rgba(201, 48, 44, 0.2);
}

.quick-icon {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #c9302c;
  margin-bottom: 8rpx;
}

.quick-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 6rpx;
}

.quick-desc {
  font-size: 22rpx;
  display: block;
}

.points-bar {
  margin-top: 20rpx;
  font-size: 24rpx;
}

.points-num {
  color: #c9302c;
  font-weight: 600;
}

.link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.link-row:last-child {
  border-bottom: 0;
}

.arrow {
  color: #9ca3af;
  font-size: 36rpx;
}

.admin-hint {
  font-size: 22rpx;
  line-height: 1.5;
}
