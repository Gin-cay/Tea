.story-ribbon {
  text-align: center;
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(90deg, #c9302c, #e85d5d);
  padding: 14rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.block-card {
  margin-bottom: 20rpx;
}

.block-text {
  font-size: 28rpx;
  line-height: 1.75;
  color: #374151;
}

.block-img {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

.cap {
  font-size: 24rpx;
  margin-top: 12rpx;
}

.block-audio {
  width: 100%;
  margin-top: 16rpx;
}

.block-video {
  width: 100%;
  height: 360rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
}

.tip {
  font-size: 24rpx;
  margin-top: 12rpx;
  line-height: 1.5;
}

.small {
  font-size: 24rpx;
  margin-top: 8rpx;
}
