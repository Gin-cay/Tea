.page {
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.quiz-head {
  margin-bottom: 20rpx;
}

.quiz-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.quiz-meta {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.timer {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #c9302c;
  font-weight: 600;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(47, 143, 58, 0.15);
}

.q-card .q-no {
  font-size: 24rpx;
  color: #2f8f3a;
  margin-bottom: 12rpx;
}

.q-text {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.opt {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.opt-on {
  border-color: #2f8f3a;
  background: rgba(47, 143, 58, 0.08);
}

.opt-dot {
  flex-shrink: 0;
  color: #2f8f3a;
}

.muted {
  color: #6b7280;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(245, 247, 242, 0.96);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-submit-quiz {
  margin: 0;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2f8f3a;
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
}

.btn-submit-quiz::after {
  border: none;
}
