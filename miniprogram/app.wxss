page {
  background-color: #f5f7f2;
  color: #1f2937;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.muted {
  color: #6b7280;
}

/* ========== 资料完善遮罩（方案A：不跳转，全屏拦截）========== */
.profile-gate {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
}

.profile-gate__mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(17, 24, 39, 0.45);
}

.profile-gate__card {
  position: absolute;
  left: 50%;
  top: 38%;
  transform: translate(-50%, -50%);
  width: calc(100% - 72rpx);
  max-width: 620rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 26rpx;
  box-sizing: border-box;
}

.profile-gate__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.profile-gate__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #6b7280;
}

.profile-gate__missing {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(237, 247, 236, 0.55);
  border: 1rpx solid rgba(47, 143, 58, 0.12);
  font-size: 24rpx;
  color: #374151;
}

.profile-gate__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-gate__btn,
.profile-gate__btn--primary {
  flex: 1;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.profile-gate__btn {
  color: #2f8f3a;
  background: #fff;
  border: 1rpx solid rgba(47, 143, 58, 0.18);
}

.profile-gate__btn--primary {
  color: #fff;
  background: #2f8f3a;
  border: none;
}

.profile-gate__btn::after,
.profile-gate__btn--primary::after {
  border: none;
}